# ── Backend environment variables ───────────────────────────
# Copy this file to .env and fill in your values

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
RUN_MIGRATIONS=false

# PostgreSQL (optional — app works without DB in demo mode)
# Neon production URLs should use sslmode=verify-full to avoid pg SSL warnings.
DATABASE_URL=postgresql://claimbot:password@localhost:5432/claimbot

# GenLayer Bradbury
# Browser wallets sign user transactions. The backend uses these values for reads,
# health checks, and legacy demo-compatible tooling.
GENLAYER_ENDPOINT=https://rpc-bradbury.genlayer.com
CONTRACT_ADDRESS=0x5c5C18e0B7bD4EfF63C89C7077DAA64f2F4356d1
# Optional: only needed for backend maintenance scripts, not normal user actions.
GENLAYER_PRIVATE_KEY=

# Set to "true" to run with mock data (no DB or deployed contract needed)
DEMO_MODE=true
