# ── Backend environment variables ───────────────────────────
# Copy this file to .env and fill in your values

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
RUN_MIGRATIONS=false

# PostgreSQL (optional — app works without DB in demo mode)
DATABASE_URL=postgresql://claimbot:password@localhost:5432/claimbot

# GenLayer
GENLAYER_ENDPOINT=https://testnet.genlayer.com
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
ADMIN_WALLET=0x0000000000000000000000000000000000000000

# Set to "true" to run with mock data (no DB or deployed contract needed)
DEMO_MODE=true
