# ── Frontend environment variables ──────────────────────────
# Copy this file to .env.local and fill in your values

# Backend API URL (your Express server)
NEXT_PUBLIC_API_URL=http://localhost:4000
# Alias supported for Vercel/older docs
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# GenLayer Bradbury RPC endpoint
NEXT_PUBLIC_GENLAYER_ENDPOINT=https://rpc-bradbury.genlayer.com

# Deployed ClaimBot Bradbury contract address
NEXT_PUBLIC_CONTRACT_ADDRESS=0x5c5C18e0B7bD4EfF63C89C7077DAA64f2F4356d1
